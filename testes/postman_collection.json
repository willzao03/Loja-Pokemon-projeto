  "item": [
    {
      "name": "API Pokémon TCG",
      "item": [
        {
          "name": "CT-08 | Busca válida – Charizard",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Retorna ao menos 1 carta', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.length).to.be.above(0);",
                  "});",
                  "pm.test('Carta contém campo name', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data[0]).to.have.property('name');",
                  "});",
                  "console.log('Cartas retornadas:', pm.response.json().data.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.pokemontcg.io/v2/cards?q=name:Charizard&pageSize=1",
              "protocol": "https",
              "host": ["api", "pokemontcg", "io"],
              "path": ["v2", "cards"],
              "query": [
                { "key": "q", "value": "name:Charizard" },
                { "key": "pageSize", "value": "1" }
              ]
            }
          }
        },
